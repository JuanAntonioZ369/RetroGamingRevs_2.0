{
  "name": "gamingrevs",
  "version": "1.0.0",
  "description": "GamingRevs — Launcher de PS1 con netplay",
  "author": "AntonioPCGamer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "electron-updater": "^6.1.7",
    "yauzl": "^2.10.0"
  },
  "devDependencies": {
    "docx": "^9.7.1",
    "electron": "^25.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gamingrevs.launcher",
    "productName": "GamingRevs",
    "copyright": "Copyright © 2025 GamingRevs",
    "asar": false,
    "files": [
      "**/*",
      "!games/**",
      "!**/*.cue",
      "!**/*.img",
      "!**/*.mcr",
      "!**/*.mcs",
      "!**/*.srm",
      "!**/*.state*",
      "!Emuladores/mednafen-1.32.1-win64/firmware/**",
      "!Emuladores/RetroArch-Win64/system/scph*",
      "!Emuladores/mednafen-1.32.1-win64/sav/**",
      "!Emuladores/mednafen-1.32.1-win64/mcs/**",
      "!Emuladores/RetroArch-Win64/saves/**",
      "!Emuladores/RetroArch-Win64/states/**",
      "!Emuladores/mednafen-1.32.1-win64/stdout.txt",
      "!Emuladores/mednafen-1.32.1-win64/stderr.txt",
      "!Emuladores/mednafen-1.32.1-win64/mednafen.lck",
      "!userData.json",
      "!node_modules/docx/**",
      "!**/*.sql",
      "!**/*.docx",
      "!.claude/**",
      "!dist/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "pngLogos/logoPrimary.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "GamingRevs"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AntonioPCGamer",
        "repo": "NewGameRev",
        "releaseType": "release"
      }
    ]
  }
}
